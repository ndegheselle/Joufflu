<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <Thickness x:Key="{x:Static joufflu:Dimensions.BorderThickness}">1</Thickness>
    <CornerRadius x:Key="{x:Static joufflu:Dimensions.CornerRadius}">8</CornerRadius>
    <Thickness x:Key="{x:Static joufflu:Dimensions.Spacing}">12</Thickness>

    <!-- Vertical size of single line controls -->
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlHeightXs}">24</system:Double>
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlHeightSm}">28</system:Double>
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlHeightMd}">32</system:Double>
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlHeightLg}">40</system:Double>

    <!-- Font size -->
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlFontSizeXs}">11</system:Double>
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlFontSizeSm}">12</system:Double>
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlFontSizeMd}">13</system:Double>
    <system:Double x:Key="{x:Static joufflu:Dimensions.ControlFontSizeLg}">15</system:Double>

    <!-- Control paddings  -->
    <Thickness x:Key="{x:Static joufflu:Dimensions.ControlPaddingXs}">4,2</Thickness>
    <Thickness x:Key="{x:Static joufflu:Dimensions.ControlPaddingSm}">6,3</Thickness>
    <Thickness x:Key="{x:Static joufflu:Dimensions.ControlPaddingMd}">8,4</Thickness>
    <Thickness x:Key="{x:Static joufflu:Dimensions.ControlPaddingLg}">12,6</Thickness>

</ResourceDictionary>
