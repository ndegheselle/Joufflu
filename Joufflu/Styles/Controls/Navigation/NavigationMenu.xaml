<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts"
    xmlns:joufflu="clr-namespace:Joufflu"
    xmlns:nav="clr-namespace:Joufflu.Navigation">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Joufflu;component/Styles/Dimensions.xaml" />
    </ResourceDictionary.MergedDictionaries>
    
    <!--  ============================ NavigationItem ============================  -->
    <Style TargetType="{x:Type nav:NavigationItem}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationItem}">
                    <Button
                        x:Name="ItemButton"
                        Style="{DynamicResource Ghost}"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}"
                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter
                                x:Name="IconPresenter"
                                Grid.Column="0"
                                Width="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Icon}" />

                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <!--  Recolors custom content, which inherits Foreground from the NavigationItem (not the ItemButton)  -->
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryContentBrush}}" />
                            <Setter TargetName="ItemButton" Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryBrush}}" />
                            <!--  The icon inherits from the ItemButton, so it needs its own override  -->
                            <Setter TargetName="ItemButton" Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryContentBrush}}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}" Value="True">
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================ NavigationGroup ============================  -->
    <Style TargetType="{x:Type nav:NavigationGroup}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationGroup}">
                    <StackPanel>
                        <Button
                            x:Name="HeaderButton"
                        HorizontalContentAlignment="Stretch"
                        Style="{DynamicResource Ghost}"
                            Command="{Binding ToggleCommand, RelativeSource={RelativeSource TemplatedParent}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter
                                    x:Name="IconPresenter"
                                    Grid.Column="0"
                                    Width="24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding Icon}" />

                                <ContentPresenter
                                    x:Name="ContentPresenter"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    ContentSource="Header" />

                                <fonts:FontIcon
                                    x:Name="Chevron"
                                    Grid.Column="2"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Text="{x:Static fonts:LucideFontIcons.ChevronDown}" />
                            </Grid>
                        </Button>

                        <Border
                            x:Name="ChildrenHost"
                            Margin="16,0,0,0"
                            Padding="8,0,0,0"
                            BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                            BorderThickness="1,0,0,0"
                            Visibility="Collapsed">
                            <ItemsPresenter />
                        </Border>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ChildrenHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Chevron" Property="Text" Value="{x:Static fonts:LucideFontIcons.ChevronUp}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}" Value="True">
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="Chevron" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ChildrenHost" Property="Margin" Value="0" />
                            <Setter TargetName="ChildrenHost" Property="Padding" Value="0" />
                            <Setter TargetName="ChildrenHost" Property="BorderThickness" Value="0" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================ NavigationTitle ============================  -->
    <Style TargetType="{x:Type nav:NavigationTitle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationTitle}">
                    <Grid Margin="0,12,0,4">
                        <TextBlock
                            x:Name="TitleText"
                            Margin="8,0,0,0"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                            Text="{TemplateBinding Title}" />
                        <Border
                            x:Name="TitleLine"
                            Height="{StaticResource {x:Static joufflu:Dimensions.Thickness}}"
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                            Visibility="Collapsed" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}" Value="True">
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TitleLine" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================ NavigationMenu ============================  -->
    <Style TargetType="{x:Type nav:NavigationMenu}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}" />
        <Setter Property="BorderThickness">
            <Setter.Value>
                <Thickness Right="{StaticResource {x:Static joufflu:Dimensions.Thickness}}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Width" Value="220" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationMenu}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <DockPanel>
                            <Button
                                x:Name="CollapseButton"
                                Width="32"
                                Height="32"
                                Margin="8"
                                Padding="0"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding ToggleCollapseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                DockPanel.Dock="Top">
                                <fonts:FontIcon
                                    x:Name="CollapseIcon"
                                    FontSize="18"
                                    Text="{x:Static fonts:LucideFontIcons.PanelLeftClose}" />
                            </Button>

                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter Margin="8,0,8,8" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCollapsed" Value="True">
                            <Setter Property="Width" Value="auto" />
                            <Setter TargetName="CollapseButton" Property="HorizontalAlignment" Value="Center" />
                            <Setter TargetName="CollapseIcon" Property="Text" Value="{x:Static fonts:LucideFontIcons.PanelLeftOpen}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
