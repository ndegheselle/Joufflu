<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts"
    xmlns:joufflu="clr-namespace:Joufflu"
    xmlns:nav="clr-namespace:Joufflu.Navigation">

    <!--  ============================ NavigationItem ============================  -->
    <Style TargetType="{x:Type nav:NavigationItem}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationItem}">
                    <Button
                        x:Name="ItemButton"
                        Height="40"
                        Margin="0,2"
                        Padding="8,0"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}"
                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter
                                x:Name="IconPresenter"
                                Grid.Column="0"
                                Width="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Icon}" />

                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemButton" Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryBrush}}" />
                            <Setter TargetName="ItemButton" Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryContentBrush}}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}" Value="True">
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================ NavigationTitle ============================  -->
    <Style TargetType="{x:Type nav:NavigationTitle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationTitle}">
                    <Grid Margin="0,12,0,4">
                        <TextBlock
                            x:Name="TitleText"
                            Margin="8,0,0,0"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                            Text="{TemplateBinding Title}" />
                        <Border
                            x:Name="TitleLine"
                            Height="1"
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                            Visibility="Collapsed" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}" Value="True">
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TitleLine" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================ NavigationMenu ============================  -->
    <Style TargetType="{x:Type nav:NavigationMenu}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Width" Value="220" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationMenu}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <DockPanel>
                            <Button
                                x:Name="CollapseButton"
                                Width="32"
                                Height="32"
                                Margin="8"
                                Padding="0"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding ToggleCollapseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                DockPanel.Dock="Top">
                                <fonts:FontIcon
                                    x:Name="CollapseIcon"
                                    FontSize="18"
                                    Text="{x:Static fonts:LucideFontIcons.PanelLeftClose}" />
                            </Button>

                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter Margin="8,0,8,8" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCollapsed" Value="True">
                            <Setter Property="Width" Value="56" />
                            <Setter TargetName="CollapseButton" Property="HorizontalAlignment" Value="Center" />
                            <Setter TargetName="CollapseIcon" Property="Text" Value="{x:Static fonts:LucideFontIcons.PanelLeftOpen}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
