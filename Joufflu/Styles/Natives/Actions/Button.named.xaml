<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Joufflu;component/Styles/Natives/Actions/Button.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Joufflu;component/Styles/Natives/Actions/ToggleButton.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Soft/outline tints. The soft background is the semantic hue at low opacity rather than a
        dedicated palette colour, so it is derived automatically for the built-in themes and for any
        custom theme (the Color is a DynamicResource; only the opacity is fixed). The "Soft" brush is
        the resting fill and doubles as the outline hover; "SoftStrong" is the soft hover.
        Secondary is achromatic, so its soft treatment is a neutral foreground wash instead of a hue.
    -->
    <SolidColorBrush
        x:Key="PrimarySoftBrush"
        Opacity="0.14"
        Color="{DynamicResource {x:Static joufflu:Colors.PrimaryColor}}" />
    <SolidColorBrush
        x:Key="PrimarySoftStrongBrush"
        Opacity="0.24"
        Color="{DynamicResource {x:Static joufflu:Colors.PrimaryColor}}" />

    <SolidColorBrush
        x:Key="SecondarySoftBrush"
        Opacity="0.08"
        Color="{DynamicResource {x:Static joufflu:Colors.SecondaryColor}}" />
    <SolidColorBrush
        x:Key="SecondarySoftStrongBrush"
        Opacity="0.14"
        Color="{DynamicResource {x:Static joufflu:Colors.SecondaryColor}}" />

    <SolidColorBrush
        x:Key="SuccessSoftBrush"
        Opacity="0.14"
        Color="{DynamicResource {x:Static joufflu:Colors.SuccessColor}}" />
    <SolidColorBrush
        x:Key="SuccessSoftStrongBrush"
        Opacity="0.24"
        Color="{DynamicResource {x:Static joufflu:Colors.SuccessColor}}" />

    <SolidColorBrush
        x:Key="InfoSoftBrush"
        Opacity="0.14"
        Color="{DynamicResource {x:Static joufflu:Colors.InfoColor}}" />
    <SolidColorBrush
        x:Key="InfoSoftStrongBrush"
        Opacity="0.24"
        Color="{DynamicResource {x:Static joufflu:Colors.InfoColor}}" />

    <SolidColorBrush
        x:Key="WarningSoftBrush"
        Opacity="0.14"
        Color="{DynamicResource {x:Static joufflu:Colors.WarningColor}}" />
    <SolidColorBrush
        x:Key="WarningSoftStrongBrush"
        Opacity="0.24"
        Color="{DynamicResource {x:Static joufflu:Colors.WarningColor}}" />

    <SolidColorBrush
        x:Key="DangerSoftBrush"
        Opacity="0.14"
        Color="{DynamicResource {x:Static joufflu:Colors.DangerColor}}" />
    <SolidColorBrush
        x:Key="DangerSoftStrongBrush"
        Opacity="0.24"
        Color="{DynamicResource {x:Static joufflu:Colors.DangerColor}}" />

    <Style
        x:Key="Ghost"
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style
        x:Key="Primary"
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Primary100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="Secondary"
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.SecondaryContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.SecondaryBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Secondary100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="Success"
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.SuccessContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.SuccessBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Success100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="Info"
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.InfoContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.InfoBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Info100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="Warning"
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.WarningContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.WarningBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Warning100Brush}}" />
            </Trigger>
        </Style.Triggers>
