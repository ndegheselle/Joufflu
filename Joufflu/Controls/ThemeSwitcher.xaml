<UserControl
    x:Class="Joufflu.Controls.ThemeSwitcher"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Joufflu.Converters"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts"
    xmlns:joufflu="clr-namespace:Joufflu"
    xmlns:themes="clr-namespace:Joufflu.Themes">

    <UserControl.Resources>
        <conv:EnumMatchToBooleanConverter x:Key="EnumMatch" />

        <!--  A segment reuses the toggle-button look: highlighted when its mode is active.  -->
        <Style
            x:Key="SegmentStyle"
            BasedOn="{StaticResource {x:Type ToggleButton}}"
            TargetType="{x:Type RadioButton}">
            <Setter Property="GroupName" Value="JoufffluThemeMode" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <StackPanel
        Orientation="Horizontal"
        joufflu:Spacing.Gap="6,0">

        <RadioButton
            Style="{StaticResource SegmentStyle}"
            ToolTip="Follow the system theme"
            IsChecked="{Binding Mode, Source={x:Static themes:ThemeManager.Instance}, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static themes:ThemeMode.System}, Mode=TwoWay}">
            <StackPanel Orientation="Horizontal" joufflu:Spacing.Gap="6,0">
                <fonts:FontIcon VerticalAlignment="Center" Text="{x:Static fonts:LucideFontIcons.Monitor}" />
                <TextBlock VerticalAlignment="Center" Text="System" />
            </StackPanel>
        </RadioButton>

        <RadioButton
            Style="{StaticResource SegmentStyle}"
            ToolTip="Use the light theme"
            IsChecked="{Binding Mode, Source={x:Static themes:ThemeManager.Instance}, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static themes:ThemeMode.Light}, Mode=TwoWay}">
            <StackPanel Orientation="Horizontal" joufflu:Spacing.Gap="6,0">
                <fonts:FontIcon VerticalAlignment="Center" Text="{x:Static fonts:LucideFontIcons.Sun}" />
                <TextBlock VerticalAlignment="Center" Text="Light" />
            </StackPanel>
        </RadioButton>

        <RadioButton
            Style="{StaticResource SegmentStyle}"
            ToolTip="Use the dark theme"
            IsChecked="{Binding Mode, Source={x:Static themes:ThemeManager.Instance}, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static themes:ThemeMode.Dark}, Mode=TwoWay}">
            <StackPanel Orientation="Horizontal" joufflu:Spacing.Gap="6,0">
                <fonts:FontIcon VerticalAlignment="Center" Text="{x:Static fonts:LucideFontIcons.Moon}" />
                <TextBlock VerticalAlignment="Center" Text="Dark" />
            </StackPanel>
        </RadioButton>
    </StackPanel>
</UserControl>
