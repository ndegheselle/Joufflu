  </ItemGroup>

  <ItemGroup>
    <Page Update="Controls\ComboBoxSearch.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Controls\ComboBoxTags.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Controls\DecimalUpDown.xaml">
