<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:local="clr-namespace:Joufflu.Inputs.Controls">

    <!--  Checkerboard shown behind translucent colours (alpha slider + swatches).  -->
    <DrawingBrush
        x:Key="ColorPickerCheckerBrush"
        Stretch="None"
        TileMode="Tile"
        Viewport="0,0,12,12"
        ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,12,12" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#D0D0D0">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,6,6" />
                            <RectangleGeometry Rect="6,6,6,6" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!--  Round white knob used by the hue/alpha slider thumbs.  -->
    <Style x:Key="ColorPickerSliderThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid>
                        <Ellipse
                            Fill="White"
                            Stroke="#40000000"
                            StrokeThickness="1">
                            <Ellipse.Effect>
                                <DropShadowEffect
                                    BlurRadius="4"
                                    Direction="270"
                                    Opacity="0.35"
                                    ShadowDepth="1" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ColorPickerSliderRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Horizontal slider whose track is a caller-provided gradient (hue rainbow / alpha ramp).  -->
    <Style x:Key="ColorPickerBarSlider" TargetType="{x:Type Slider}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Height" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid>
                        <!--  Track background is supplied through Slider.Background  -->
                        <Border
                            Height="12"
                            VerticalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                            BorderThickness="{StaticResource {x:Static joufflu:Dimensions.BorderThickness}}"
                            CornerRadius="6" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource ColorPickerSliderRepeatButton}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ColorPickerSliderThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource ColorPickerSliderRepeatButton}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:ColorPicker}">
        <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlHeightMd}}" />
        <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlFontSizeMd}}" />
        <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlPaddingMd}}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ColorPicker}">
                    <Grid
                        x:Name="Root"
                        joufflu:Spacing.Gap="4"
                        DataContext="{Binding RelativeSource={RelativeSource AncestorType=local:ColorPicker}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Editable hex value: paste or type a #RRGGBB / #AARRGGBB colour  -->
                        <TextBox
                            Grid.Column="0"
                            MinWidth="100"
                            VerticalContentAlignment="Center"
                            FontFamily="Consolas, Cascadia Mono, monospace"
                            MaxLength="9"
                            Text="{Binding HexText, UpdateSourceTrigger=LostFocus}" />

                        <!--  Swatch button: click to open the picker popup  -->
                        <ToggleButton
                            x:Name="SwatchButton"
                            Grid.Column="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            joufflu:ControlProperties.IsSquare="True"
                            BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                            BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}">
                            <Grid Margin="2">
                                <Border
                                    Margin="1"
                                    Background="{DynamicResource ColorPickerCheckerBrush}"
                                    CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}" />
                                <Border Background="{Binding SwatchBrush}" CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}" />
                            </Grid>
                        </ToggleButton>

                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsChecked, ElementName=SwatchButton}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=SwatchButton}"
                            StaysOpen="False">
                            <!--  DataContext doesn't reliably inherit into a templated Popup's separate visual tree, so flow it in explicitly.  -->
                            <Border
                                Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}"
                                Background="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}"
                                BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                                BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
                                CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}"
                                DataContext="{Binding DataContext, ElementName=Root}">
                                <StackPanel Width="240" joufflu:Spacing.Gap="4">

                                    <!--  Saturation / brightness square  -->
                                    <Border Height="150">
                                        <Grid x:Name="PART_SaturationArea" Cursor="Cross">
                                            <!--  Pure-hue base; the gradients on top build the saturation/brightness field  -->
                                            <Border Background="{Binding HueBrush}" />
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Offset="0" Color="#FFFFFFFF" />
                                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!--  Transparent -> black (bottom) gives the brightness axis  -->
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Offset="0" Color="#00000000" />
                                                        <GradientStop Offset="1" Color="#FF000000" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!--  Selector knob; positioned in code via a TranslateTransform  -->
                                            <Grid
                                                x:Name="PART_SaturationSelector"
                                                Width="16"
                                                Height="16"
                                                Margin="-8"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                IsHitTestVisible="False">
                                                <Ellipse
                                                    Fill="{Binding OpaqueBrush}"
                                                    Stroke="White"
                                                    StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect
                                                            BlurRadius="4"
                                                            Opacity="0.4"
                                                            ShadowDepth="0" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!--  Hue slider  -->
                                    <Slider
                                        Maximum="360"
                                        Minimum="0"
                                        SmallChange="1"
                                        Style="{StaticResource ColorPickerBarSlider}"
                                        Value="{Binding Hue, Mode=TwoWay}">
                                        <Slider.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Offset="0.00" Color="#FF0000" />
                                                <GradientStop Offset="0.17" Color="#FFFF00" />
                                                <GradientStop Offset="0.33" Color="#00FF00" />
                                                <GradientStop Offset="0.50" Color="#00FFFF" />
                                                <GradientStop Offset="0.67" Color="#0000FF" />
                                                <GradientStop Offset="0.83" Color="#FF00FF" />
                                                <GradientStop Offset="1.00" Color="#FF0000" />
                                            </LinearGradientBrush>
                                        </Slider.Background>
                                    </Slider>

                                    <!--  Alpha slider (checkerboard behind a transparent->opaque ramp)  -->
                                    <Grid>
                                        <Border
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource ColorPickerCheckerBrush}"
                                            CornerRadius="6" />
                                        <Slider
                                            Maximum="1"
                                            Minimum="0"
                                            SmallChange="0.01"
                                            Style="{StaticResource ColorPickerBarSlider}"
                                            Value="{Binding Alpha, Mode=TwoWay}">
                                            <Slider.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="Transparent" />
                                                    <GradientStop Offset="1" Color="{Binding OpaqueBrush.Color}" />
                                                </LinearGradientBrush>
                                            </Slider.Background>
                                        </Slider>
                                    </Grid>

                                    <!--  Swatch + hex + opacity readout  -->
                                    <Grid joufflu:Spacing.Gap="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            Grid.Column="0"
                                            VerticalContentAlignment="Center"
                                            FontFamily="Consolas, Cascadia Mono, monospace"
                                            MaxLength="9"
                                            Text="{Binding HexText, UpdateSourceTrigger=LostFocus}" />

                                        <Grid Grid.Column="1" MinWidth="56">
                                            <TextBox
                                                Padding="6,0,18,0"
                                                VerticalContentAlignment="Center"
                                                Text="{Binding AlphaPercent, StringFormat={}{0:0}, UpdateSourceTrigger=LostFocus}"
                                                TextAlignment="Right" />
                                            <TextBlock
                                                Margin="0,0,6,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                                                IsHitTestVisible="False"
                                                Text="%" />
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <!--  Size variants  -->
            <Trigger Property="joufflu:ControlProperties.Size" Value="xs">
                <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlHeightXs}}" />
                <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlFontSizeXs}}" />
                <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlPaddingXs}}" />
            </Trigger>
            <Trigger Property="joufflu:ControlProperties.Size" Value="sm">
                <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlHeightSm}}" />
                <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlFontSizeSm}}" />
                <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlPaddingSm}}" />
            </Trigger>
            <Trigger Property="joufflu:ControlProperties.Size" Value="lg">
                <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlHeightLg}}" />
                <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlFontSizeLg}}" />
                <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Dimensions.ControlPaddingLg}}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
