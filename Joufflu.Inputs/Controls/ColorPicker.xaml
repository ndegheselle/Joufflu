<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:local="clr-namespace:Joufflu.Inputs.Controls">

    <Style TargetType="{x:Type local:ColorPicker}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ColorPicker}">
                    <Grid x:Name="Root" DataContext="{Binding RelativeSource={RelativeSource AncestorType=local:ColorPicker}}" joufflu:Spacing.HorizontalGap="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Editable hex value: paste or type a #AARRGGBB / #RRGGBB colour  -->
                        <TextBox
                            Grid.Column="0"
                            MinWidth="100"
                            VerticalContentAlignment="Center"
                            FontFamily="Consolas, Cascadia Mono, monospace"
                            MaxLength="9"
                            Text="{Binding HexText, UpdateSourceTrigger=LostFocus}" />

                        <!--  Swatch button: click to open the RGBA popup and pick manually  -->
                        <ToggleButton
                            x:Name="SwatchButton"
                            Grid.Column="1"
                            Width="32"
                            Height="{StaticResource {x:Static joufflu:Dimensions.ControlHeightSm}}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Padding="0"
                            BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                            BorderThickness="{StaticResource {x:Static joufflu:Dimensions.BorderThickness}}">
                            <Border
                                Margin="3"
                                Background="{Binding SwatchBrush}"
                                CornerRadius="{StaticResource {x:Static joufflu:Dimensions.CornerRadius}}" />
                        </ToggleButton>

                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsChecked, ElementName=SwatchButton}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=SwatchButton}"
                            StaysOpen="False">
                            <!--  DataContext doesn't reliably inherit into a templated Popup's separate visual tree, so flow it in explicitly.  -->
                            <Border
                                Margin="0,4,0,0"
                                DataContext="{Binding DataContext, ElementName=Root}"
                                Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}"
                                Background="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}"
                                BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                                BorderThickness="{StaticResource {x:Static joufflu:Dimensions.BorderThickness}}"
                                CornerRadius="{StaticResource {x:Static joufflu:Dimensions.CornerRadius}}">
                                <StackPanel Width="220" joufflu:Spacing.VerticalGap="6">
                                    <Border
                                        Height="40"
                                        Background="{Binding SwatchBrush}"
                                        BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                                        BorderThickness="{StaticResource {x:Static joufflu:Dimensions.BorderThickness}}"
                                        CornerRadius="{StaticResource {x:Static joufflu:Dimensions.CornerRadius}}" />

                                    <Grid joufflu:Spacing.Gap="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="R" />
                                        <Slider Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Maximum="255" Minimum="0" SmallChange="1" Value="{Binding R, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" Text="{Binding R, StringFormat=0}" TextAlignment="Right" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="G" />
                                        <Slider Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Maximum="255" Minimum="0" SmallChange="1" Value="{Binding G, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" Text="{Binding G, StringFormat=0}" TextAlignment="Right" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="B" />
                                        <Slider Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Maximum="255" Minimum="0" SmallChange="1" Value="{Binding B, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" Text="{Binding B, StringFormat=0}" TextAlignment="Right" />

                                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="A" />
                                        <Slider Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Maximum="255" Minimum="0" SmallChange="1" Value="{Binding A, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="3" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" Text="{Binding A, StringFormat=0}" TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
