<controls:ThemedWindow
    x:Class="Joufflu.Samples.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Joufflu.Controls;assembly=Joufflu"
    xmlns:converters="clr-namespace:Joufflu.Converters;assembly=Joufflu"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nav="clr-namespace:Joufflu.Navigation.Controls;assembly=Joufflu.Navigation"
    xmlns:vm="clr-namespace:Joufflu.Samples.ViewModels"
    Width="1100"
    Height="720"
    d:DataContext="{d:DesignInstance Type=vm:AppViewModel}"
    IconVisibility="Collapsed"
    PlaceTitleBarOverContent="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <controls:ThemedWindow.Resources>
        <converters:TopThicknessConverter x:Key="TopThickness" />
    </controls:ThemedWindow.Resources>
    <DockPanel>
        <nav:NavigationMenu
            DockPanel.Dock="Left"
            Navigator="{Binding Navigator}"
            Padding="{Binding TitleBarActualHeight, RelativeSource={RelativeSource AncestorType={x:Type controls:ThemedWindow}}, Converter={StaticResource TopThickness}}"
            TargetResolver="{Binding ResolveTarget}">
            <nav:NavigationMenu.Header>
                <StackPanel
                    VerticalAlignment="Center"
                    joufflu:Spacing.Gap="8"
                    Orientation="Horizontal">
                    <fonts:FontIcon FontSize="20" Text="{x:Static fonts:LucideFontIcons.Rocket}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="Joufflu" />
                </StackPanel>
            </nav:NavigationMenu.Header>

            <!--  Featured native controls (kept at top level)  -->

            <nav:NavigationTitle Title="Natives" />

            <nav:NavigationItem Target="natives/buttons">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.MousePointerClick}" />
                </nav:NavigationItem.Icon>
                Buttons
            </nav:NavigationItem>
            <nav:NavigationItem Target="natives/typography">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Type}" />
                </nav:NavigationItem.Icon>
                Typography
            </nav:NavigationItem>
            <nav:NavigationItem Target="natives/card">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Square}" />
                </nav:NavigationItem.Icon>
                Card
            </nav:NavigationItem>

            <!--  All other native controls, grouped and closed by default  -->
            <nav:NavigationGroup Header="Native controls">
                <nav:NavigationGroup.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Blocks}" />
                </nav:NavigationGroup.Icon>

                <nav:NavigationTitle Title="Actions" />
                <nav:NavigationItem Target="natives/toggle-buttons">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.ToggleLeft}" />
                    </nav:NavigationItem.Icon>
                    Toggle buttons
                </nav:NavigationItem>

                <nav:NavigationTitle Title="Data input" />
                <nav:NavigationItem Target="natives/text-box">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.TextCursorInput}" />
                    </nav:NavigationItem.Icon>
                    Text box
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/combo-box">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.List}" />
                    </nav:NavigationItem.Icon>
                    Combo box
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/check-box">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.CheckSquare}" />
                    </nav:NavigationItem.Icon>
                    Check box
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/radio-button">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.CircleDot}" />
                    </nav:NavigationItem.Icon>
                    Radio button
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/slider">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.SlidersHorizontal}" />
                    </nav:NavigationItem.Icon>
                    Slider
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/date-picker">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Calendar}" />
                    </nav:NavigationItem.Icon>
                    Date picker
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/calendar">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.CalendarDays}" />
                    </nav:NavigationItem.Icon>
                    Calendar
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/list-box">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.LayoutList}" />
                    </nav:NavigationItem.Icon>
                    List box
                </nav:NavigationItem>

                <nav:NavigationTitle Title="Data display" />
                <nav:NavigationItem Target="natives/label">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Tag}" />
                    </nav:NavigationItem.Icon>
                    Label
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/list-view">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Table}" />
                    </nav:NavigationItem.Icon>
                    List view
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/tree-view">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Layers2}" />
                    </nav:NavigationItem.Icon>
                    Tree view
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/data-grid">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Table2}" />
                    </nav:NavigationItem.Icon>
                    Data grid
                </nav:NavigationItem>

                <nav:NavigationTitle Title="Feedback" />
                <nav:NavigationItem Target="natives/progress-bar">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Loader}" />
                    </nav:NavigationItem.Icon>
                    Progress bar
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/status-bar">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.PanelBottom}" />
                    </nav:NavigationItem.Icon>
                    Status bar
                </nav:NavigationItem>

                <nav:NavigationTitle Title="Layout" />
                <nav:NavigationItem Target="natives/group-box">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Component}" />
                    </nav:NavigationItem.Icon>
                    Group box
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/expander">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.PanelTop}" />
                    </nav:NavigationItem.Icon>
                    Expander
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/scroll-viewer">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Move}" />
                    </nav:NavigationItem.Icon>
                    Scroll viewer
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/grid-splitter">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.StretchHorizontal}" />
                    </nav:NavigationItem.Icon>
                    Grid splitter
                </nav:NavigationItem>

                <nav:NavigationTitle Title="Navigation" />
                <nav:NavigationItem Target="natives/menu">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Menu}" />
                    </nav:NavigationItem.Icon>
                    Menu
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/tab-control">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.GalleryHorizontal}" />
                    </nav:NavigationItem.Icon>
                    Tab control
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/tool-bar">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Wrench}" />
                    </nav:NavigationItem.Icon>
                    Tool bar
                </nav:NavigationItem>
                <nav:NavigationItem Target="natives/hyperlink">
                    <nav:NavigationItem.Icon>
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Link}" />
                    </nav:NavigationItem.Icon>
                    Hyperlink
                </nav:NavigationItem>
            </nav:NavigationGroup>

            <!--  Inputs (Joufflu.Inputs library)  -->
            <nav:NavigationTitle Title="Inputs" />
            <nav:NavigationItem Target="inputs/numeric">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Hash}" />
                </nav:NavigationItem.Icon>
                Numeric inputs
            </nav:NavigationItem>
            <nav:NavigationItem Target="inputs/search">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.ListFilter}" />
                </nav:NavigationItem.Icon>
                Search &amp; combo
            </nav:NavigationItem>
            <nav:NavigationItem Target="inputs/combo-box-tags">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Tags}" />
                </nav:NavigationItem.Icon>
                Combo box tags
            </nav:NavigationItem>
            <nav:NavigationItem Target="inputs/text-editable">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Pencil}" />
                </nav:NavigationItem.Icon>
                Text editable
            </nav:NavigationItem>
            <nav:NavigationItem Target="inputs/file-picker">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.File}" />
                </nav:NavigationItem.Icon>
                File picker
            </nav:NavigationItem>
            <nav:NavigationItem Target="inputs/color-picker">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Palette}" />
                </nav:NavigationItem.Icon>
                Color picker
            </nav:NavigationItem>

            <!--  Navigation (Joufflu.Navigation library)  -->
            <nav:NavigationTitle Title="Navigation" />
            <nav:NavigationItem Target="navigation/menu">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.PanelLeft}" />
                </nav:NavigationItem.Icon>
                Navigation menu
            </nav:NavigationItem>
            <nav:NavigationItem Target="navigation/overlays">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.SquareStack}" />
                </nav:NavigationItem.Icon>
                Overlays
            </nav:NavigationItem>

            <!--  Custom controls  -->
            <nav:NavigationTitle Title="Custom controls" />
            <nav:NavigationItem Target="controls/font-icon">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Sparkles}" />
                </nav:NavigationItem.Icon>
                Font icon
            </nav:NavigationItem>
            <nav:NavigationItem Target="controls/badge">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Badge}" />
                </nav:NavigationItem.Icon>
                Badge
            </nav:NavigationItem>
            <nav:NavigationItem Target="controls/spinner">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Circle}" />
                </nav:NavigationItem.Icon>
                Spinner
            </nav:NavigationItem>
            <nav:NavigationItem Target="controls/toasts">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Bell}" />
                </nav:NavigationItem.Icon>
                Toasts
            </nav:NavigationItem>

            <!--  Toolkit  -->
            <nav:NavigationTitle Title="Toolkit" />
            <nav:NavigationItem Target="toolkit/sizing">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Scaling}" />
                </nav:NavigationItem.Icon>
                Sizing
            </nav:NavigationItem>
            <nav:NavigationItem Target="toolkit/spacing">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Space}" />
                </nav:NavigationItem.Icon>
                Spacing
            </nav:NavigationItem>
            <nav:NavigationItem Target="toolkit/tooltip">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.MessageSquare}" />
                </nav:NavigationItem.Icon>
                Tooltip
            </nav:NavigationItem>
            <nav:NavigationItem Target="toolkit/application-shell">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.AppWindow}" />
                </nav:NavigationItem.Icon>
                Application shell
            </nav:NavigationItem>
            <nav:NavigationItem Target="toolkit/theme">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.SunMoon}" />
                </nav:NavigationItem.Icon>
                Theme
            </nav:NavigationItem>
            <nav:NavigationItem Target="toolkit/customize-theme">
                <nav:NavigationItem.Icon>
                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Palette}" />
                </nav:NavigationItem.Icon>
                Customize theme
            </nav:NavigationItem>
        </nav:NavigationMenu>

        <nav:NavigationContainer
            Navigator="{Binding Navigator}"
            Overlays="{Binding Overlays}"
            Padding="{Binding TitleBarActualHeight, RelativeSource={RelativeSource AncestorType={x:Type controls:ThemedWindow}}, Converter={StaticResource TopThickness}}"
            Toasts="{Binding Toasts}" />
    </DockPanel>
</controls:ThemedWindow>
