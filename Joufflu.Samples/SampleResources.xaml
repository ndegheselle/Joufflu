<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:customDisplay="clr-namespace:Joufflu.Samples.Views.Controls.DataDisplay"
    xmlns:customFeedback="clr-namespace:Joufflu.Samples.Views.Controls.Feedback"
    xmlns:customNav="clr-namespace:Joufflu.Samples.Views.Controls.Navigation"
    xmlns:inputs="clr-namespace:Joufflu.Samples.Views.Inputs"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:nativeActions="clr-namespace:Joufflu.Samples.Views.Natives.Actions"
    xmlns:nativeDisplay="clr-namespace:Joufflu.Samples.Views.Natives.DataDisplay"
    xmlns:nativeFeedback="clr-namespace:Joufflu.Samples.Views.Natives.Feedback"
    xmlns:nativeInput="clr-namespace:Joufflu.Samples.Views.Natives.DataInput"
    xmlns:toolkit="clr-namespace:Joufflu.Samples.Views.Toolkit"
    xmlns:vm="clr-namespace:Joufflu.Samples.ViewModels">

    <!--  Live preview + code snippet card  -->
    <Style TargetType="{x:Type c:CodeExample}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:CodeExample}">
                    <Border Style="{StaticResource Card}">
                        <Grid joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource H2}"
                                    Text="{TemplateBinding Title}" />
                                <TextBlock
                                    x:Name="Desc"
                                    Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                                    Text="{TemplateBinding Description}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <Border
                                Grid.Row="1"
                                Style="{StaticResource CardSecondary}">
                                <ContentPresenter />
                            </Border>

                            <Border
                                x:Name="CodeArea"
                                Grid.Row="2"
                                Style="{StaticResource CardSecondary}">
                                <TextBox
                                    MaxHeight="320"
                                    Height="Auto"
                                    VerticalAlignment="Stretch"
                                    HorizontalScrollBarVisibility="Auto"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontFamily="Consolas, Cascadia Mono, monospace"
                                    Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                                    IsReadOnly="True"
                                    Text="{TemplateBinding Code}"
                                    TextWrapping="NoWrap" />
                            </Border>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Code" Value="">
                            <Setter TargetName="CodeArea" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Description" Value="">
                            <Setter TargetName="Desc" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  View model → view mapping used by the navigation container and overlays.  -->
    <!--  Only pages that have a view model need a mapping; static pages are navigated to directly.  -->

    <!--  Natives / Actions  -->
    <DataTemplate DataType="{x:Type nativeActions:ButtonSamplesViewModel}">
        <nativeActions:ButtonSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeActions:ToggleButtonSamplesViewModel}">
        <nativeActions:ToggleButtonSamples />
    </DataTemplate>

    <!--  Natives / Data input  -->
    <DataTemplate DataType="{x:Type nativeInput:TextBoxSamplesViewModel}">
        <nativeInput:TextBoxSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeInput:ComboBoxSamplesViewModel}">
        <nativeInput:ComboBoxSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeInput:CheckBoxSamplesViewModel}">
        <nativeInput:CheckBoxSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeInput:SliderSamplesViewModel}">
        <nativeInput:SliderSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeInput:DatePickerSamplesViewModel}">
        <nativeInput:DatePickerSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeInput:CalendarSamplesViewModel}">
        <nativeInput:CalendarSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeInput:ListBoxSamplesViewModel}">
        <nativeInput:ListBoxSamples />
    </DataTemplate>

    <!--  Natives / Data display  -->
    <DataTemplate DataType="{x:Type nativeDisplay:TypographySamplesViewModel}">
        <nativeDisplay:TypographySamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeDisplay:ListViewSamplesViewModel}">
        <nativeDisplay:ListViewSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeDisplay:TreeViewSamplesViewModel}">
        <nativeDisplay:TreeViewSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type nativeDisplay:DataGridSamplesViewModel}">
        <nativeDisplay:DataGridSamples />
    </DataTemplate>

    <!--  Natives / Feedback  -->
    <DataTemplate DataType="{x:Type nativeFeedback:ProgressBarSamplesViewModel}">
        <nativeFeedback:ProgressBarSamples />
    </DataTemplate>

    <!--  Controls / Data display  -->
    <DataTemplate DataType="{x:Type customDisplay:FontIconSamplesViewModel}">
        <customDisplay:FontIconSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type customDisplay:BadgeSamplesViewModel}">
        <customDisplay:BadgeSamples />
    </DataTemplate>

    <!--  Controls / Feedback  -->
    <DataTemplate DataType="{x:Type customFeedback:SpinnerSamplesViewModel}">
        <customFeedback:SpinnerSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type customFeedback:ToastSamplesViewModel}">
        <customFeedback:ToastSamples />
    </DataTemplate>

    <!--  Controls / Navigation  -->
    <DataTemplate DataType="{x:Type customNav:NavigationMenuSamplesViewModel}">
        <customNav:NavigationMenuSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type customNav:OverlaySamplesViewModel}">
        <customNav:OverlaySamples />
    </DataTemplate>

    <!--  Inputs (Joufflu.Inputs library)  -->
    <DataTemplate DataType="{x:Type inputs:NumericInputsSamplesViewModel}">
        <inputs:NumericInputsSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type inputs:SelectionInputsSamplesViewModel}">
        <inputs:SelectionInputsSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type inputs:EditorInputsSamplesViewModel}">
        <inputs:EditorInputsSamples />
    </DataTemplate>

    <!--  Toolkit  -->
    <DataTemplate DataType="{x:Type toolkit:SizingSamplesViewModel}">
        <toolkit:SizingSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type toolkit:SpacingSamplesViewModel}">
        <toolkit:SpacingSamples />
    </DataTemplate>
    <DataTemplate DataType="{x:Type toolkit:ThemeCustomizerViewModel}">
        <toolkit:ThemeCustomizer />
    </DataTemplate>

    <!--  Overlay content (shown inside overlays, not in the menu)  -->
    <DataTemplate DataType="{x:Type vm:ConfirmViewModel}">
        <customNav:ConfirmView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SampleFormViewModel}">
        <customNav:SampleFormView />
    </DataTemplate>

</ResourceDictionary>
