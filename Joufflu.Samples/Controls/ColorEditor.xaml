<UserControl
    x:Class="Joufflu.Samples.Controls.ColorEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <Grid joufflu:Spacing.HorizontalGap="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Swatch: click to open the RGBA popup  -->
        <ToggleButton
            x:Name="SwatchButton"
            Grid.Column="0"
            Width="32"
            Height="{StaticResource {x:Static joufflu:Dimensions.ControlHeightSm}}"
            Padding="0"
            BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
            BorderThickness="{StaticResource {x:Static joufflu:Dimensions.BorderThickness}}">
            <Border
                Margin="3"
                Background="{Binding SwatchBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="{StaticResource {x:Static joufflu:Dimensions.CornerRadius}}" />
        </ToggleButton>

        <TextBox
            x:Name="HexBox"
            Grid.Column="1"
            VerticalContentAlignment="Center"
            FontFamily="Consolas, Cascadia Mono, monospace"
            LostFocus="HexBox_LostFocus"
            MaxLength="9" />

        <Popup
            x:Name="EditorPopup"
            Grid.Column="0"
            AllowsTransparency="True"
            IsOpen="{Binding IsChecked, ElementName=SwatchButton}"
            Placement="Bottom"
            PlacementTarget="{Binding ElementName=SwatchButton}"
            StaysOpen="False">
            <Border
                Margin="0,4,0,0"
                Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}"
                Background="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}"
                BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                BorderThickness="{StaticResource {x:Static joufflu:Dimensions.BorderThickness}}"
                CornerRadius="{StaticResource {x:Static joufflu:Dimensions.CornerRadius}}">
                <StackPanel Width="220" joufflu:Spacing.VerticalGap="6">
                    <Border
                        Height="40"
                        Background="{Binding SwatchBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                        BorderThickness="{StaticResource {x:Static joufflu:Dimensions.BorderThickness}}"
                        CornerRadius="{StaticResource {x:Static joufflu:Dimensions.CornerRadius}}" />

                    <Grid joufflu:Spacing.Gap="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="R" />
                        <Slider x:Name="SliderR" Grid.Row="0" Grid.Column="1" Maximum="255" Minimum="0" SmallChange="1" ValueChanged="Channel_ValueChanged" />
                        <TextBlock Grid.Row="0" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" TextAlignment="Right" Text="{Binding Value, ElementName=SliderR, StringFormat=0}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="G" />
                        <Slider x:Name="SliderG" Grid.Row="1" Grid.Column="1" Maximum="255" Minimum="0" SmallChange="1" ValueChanged="Channel_ValueChanged" />
                        <TextBlock Grid.Row="1" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" TextAlignment="Right" Text="{Binding Value, ElementName=SliderG, StringFormat=0}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="B" />
                        <Slider x:Name="SliderB" Grid.Row="2" Grid.Column="1" Maximum="255" Minimum="0" SmallChange="1" ValueChanged="Channel_ValueChanged" />
                        <TextBlock Grid.Row="2" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" TextAlignment="Right" Text="{Binding Value, ElementName=SliderB, StringFormat=0}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="A" />
                        <Slider x:Name="SliderA" Grid.Row="3" Grid.Column="1" Maximum="255" Minimum="0" SmallChange="1" ValueChanged="Channel_ValueChanged" />
                        <TextBlock Grid.Row="3" Grid.Column="2" MinWidth="26" VerticalAlignment="Center" TextAlignment="Right" Text="{Binding Value, ElementName=SliderA, StringFormat=0}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
