<Application
    x:Class="Joufflu.Samples.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Joufflu.Samples">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  The active theme (Light/Dark) is inserted here at runtime by ThemeManager.Initialize().  -->
                <ResourceDictionary Source="pack://application:,,,/Joufflu;component/Resources.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Joufflu.Inputs;component/Resources.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Joufflu.Navigation;component/Resources.xaml" />
                <ResourceDictionary Source="SampleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
