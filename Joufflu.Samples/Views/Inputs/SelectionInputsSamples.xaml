<UserControl
    x:Class="Joufflu.Samples.Views.Inputs.SelectionInputsSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:inputs="clr-namespace:Joufflu.Inputs.Controls;assembly=Joufflu.Inputs"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock Style="{StaticResource H1}" Text="Search &amp; combo inputs" />

            <c:CodeExample
                Title="Search"
                Code="{Binding SearchCode}"
                Description="A text box with a built-in delay before it raises SearchChanged, to limit calls to an API or database. Escape clears it.">
                <StackPanel joufflu:Spacing.Gap="4">
                    <inputs:Search joufflu:ControlProperties.Size="xs" />
                    <inputs:Search joufflu:ControlProperties.Size="sm" />
                    <inputs:Search />
                    <inputs:Search joufflu:ControlProperties.Size="lg" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="ComboBoxSearch"
                Code="{Binding ComboSearchCode}"
                Description="An editable combo box that filters its items as you type.">
                <inputs:ComboBoxSearch
                    Width="360"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding Countries}"
                    SelectedItem="{Binding SelectedCountry, Mode=TwoWay}" />
            </c:CodeExample>

            <c:CodeExample
                Title="ComboBoxTags"
                Code="{Binding TagsCode}"
                Description="Builds on ComboBoxSearch to allow selecting several items, shown as removable tags.">
                <inputs:ComboBoxTags
                    Width="360"
                    HorizontalAlignment="Left"
                    AllowAdd="True"
                    ItemsSource="{Binding Countries}"
                    SelectedItems="{Binding SelectedCountries}" />
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
