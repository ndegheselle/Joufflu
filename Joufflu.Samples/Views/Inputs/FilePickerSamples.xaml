<UserControl
    x:Class="Joufflu.Samples.Views.Inputs.FilePickerSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:inputs="clr-namespace:Joufflu.Inputs.Controls;assembly=Joufflu.Inputs"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock Style="{StaticResource H1}" Text="File picker" />

            <c:CodeExample
                Title="FilePicker"
                Code="{Binding FilePickerCode}"
                Description="Selects a file through the system dialog and exposes the chosen path with a clear button.">
                <inputs:FilePicker
                    Width="360"
                    HorizontalAlignment="Left"
                    FilePath="{Binding FilePath, Mode=TwoWay}" />
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
