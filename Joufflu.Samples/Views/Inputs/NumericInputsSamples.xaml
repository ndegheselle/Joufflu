<UserControl
    x:Class="Joufflu.Samples.Views.Inputs.NumericInputsSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:format="clr-namespace:Joufflu.Inputs.Format;assembly=Joufflu.Inputs"
    xmlns:inputs="clr-namespace:Joufflu.Inputs;assembly=Joufflu.Inputs"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock Style="{StaticResource H1}" Text="Numeric &amp; format inputs" />

            <c:CodeExample
                Title="NumericUpDown"
                Code="{Binding NumericCode}"
                Description="Selects a whole number. Built on FormatTextBox with the numeric format, clear and increment/decrement buttons included.">
                <StackPanel joufflu:Spacing.HorizontalGap="12" Orientation="Horizontal">
                    <inputs:NumericUpDown Width="140" Value="{Binding NumericValue, Mode=TwoWay}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding NumericValue, StringFormat='Value: {0}'}" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="DecimalUpDown"
                Code="{Binding DecimalCode}"
                Description="Selects a double / decimal value using the decimal format.">
                <StackPanel joufflu:Spacing.HorizontalGap="12" Orientation="Horizontal">
                    <inputs:DecimalUpDown Width="140" Value="{Binding DecimalValue, Mode=TwoWay}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding DecimalValue, StringFormat='Value: {0}'}" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="TimeSpanPicker"
                Code="{Binding TimeSpanCode}"
                Description="Selects a TimeSpan through a days/hours/minutes/seconds format.">
                <StackPanel joufflu:Spacing.HorizontalGap="12" Orientation="Horizontal">
                    <inputs:TimeSpanPicker Width="180" Value="{Binding Duration, Mode=TwoWay}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding Duration, StringFormat='Value: {0}'}" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="FormatTextBox"
                Code="{Binding FormatCode}"
                Description="The base input: a format string describes groups that are parsed into individual values and navigated with Tab / arrows.">
                <format:FormatTextBox Width="180" Format="{}{max:23}h {max:59}m {max:59}s" />
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
