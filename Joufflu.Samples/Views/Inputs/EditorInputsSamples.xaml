<UserControl
    x:Class="Joufflu.Samples.Views.Inputs.EditorInputsSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:inputs="clr-namespace:Joufflu.Inputs.Controls;assembly=Joufflu.Inputs"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock Style="{StaticResource H1}" Text="Editors" />

            <c:CodeExample
                Title="TextEditable"
                Code="{Binding TextEditableCode}"
                Description="Displays a value that can be turned into an editable text box on demand, useful outside of a form.">
                <StackPanel joufflu:Spacing.Gap="12,0" Orientation="Horizontal">
                    <inputs:TextEditable Width="220" Text="{Binding EditableText, Mode=TwoWay}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding EditableText, StringFormat='Value: {0}'}" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="FilePicker"
                Code="{Binding FilePickerCode}"
                Description="Selects a file through the system dialog and exposes the chosen path with a clear button.">
                <inputs:FilePicker
                    Width="360"
                    HorizontalAlignment="Left"
                    FilePath="{Binding FilePath, Mode=TwoWay}" />
            </c:CodeExample>

            <c:CodeExample
                Title="ColorPicker"
                Code="{Binding ColorPickerCode}"
                Description="Edits a colour through an editable hex value and a popup with a saturation square, hue and alpha sliders.">
                <StackPanel joufflu:Spacing.Gap="12,0" Orientation="Horizontal">
                    <inputs:ColorPicker Width="220" Color="{Binding Color, Mode=TwoWay}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding Color, StringFormat='Value: {0}'}" />
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
