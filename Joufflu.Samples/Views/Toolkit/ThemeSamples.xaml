<UserControl
    x:Class="Joufflu.Samples.Views.Toolkit.ThemeSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:controls="clr-namespace:Joufflu.Controls;assembly=Joufflu"
    xmlns:conv="clr-namespace:Joufflu.Converters;assembly=Joufflu"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:themes="clr-namespace:Joufflu.Themes;assembly=Joufflu"
    xmlns:vm="clr-namespace:Joufflu.Samples.Views.Toolkit"
    d:DataContext="{d:DesignInstance Type=vm:ThemeSamplesViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:EnumMatchToBooleanConverter x:Key="EnumMatch" />
    </UserControl.Resources>
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock Style="{StaticResource H1}" Text="Theme" />
            <TextBlock
                Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                Text="System / Light / Dark, applied by swapping the active theme resource dictionary at runtime."
                TextWrapping="Wrap" />

            <c:CodeExample
                Title="Theme switcher"
                Code="{Binding SwitcherCode}"
                Description="A drop-in control bound to ThemeManager. Pick a mode and the whole gallery re-themes live; the choice is remembered across launches.">
                <StackPanel joufflu:Spacing.Gap="4">

                    <RadioButton IsChecked="{Binding Mode, Source={x:Static themes:ThemeManager.Instance}, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static themes:ThemeMode.System}, Mode=TwoWay}" ToolTip="Follow the system theme">
                        <StackPanel joufflu:Spacing.Gap="6,0" Orientation="Horizontal">
                            <fonts:FontIcon VerticalAlignment="Center" Text="{x:Static fonts:LucideFontIcons.Monitor}" />
                            <TextBlock VerticalAlignment="Center" Text="System" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton IsChecked="{Binding Mode, Source={x:Static themes:ThemeManager.Instance}, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static themes:ThemeMode.Light}, Mode=TwoWay}" ToolTip="Use the light theme">
                        <StackPanel joufflu:Spacing.Gap="6,0" Orientation="Horizontal">
                            <fonts:FontIcon VerticalAlignment="Center" Text="{x:Static fonts:LucideFontIcons.Sun}" />
                            <TextBlock VerticalAlignment="Center" Text="Light" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton IsChecked="{Binding Mode, Source={x:Static themes:ThemeManager.Instance}, Converter={StaticResource EnumMatch}, ConverterParameter={x:Static themes:ThemeMode.Dark}, Mode=TwoWay}" ToolTip="Use the dark theme">
                        <StackPanel joufflu:Spacing.Gap="6,0" Orientation="Horizontal">
                            <fonts:FontIcon VerticalAlignment="Center" Text="{x:Static fonts:LucideFontIcons.Moon}" />
                            <TextBlock VerticalAlignment="Center" Text="Dark" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="ThemeManager"
                Code="{Binding ManagerCode}"
                Description="The manager owns the active theme. Initialize it once at startup, then set Mode from anywhere. In System mode it reads the Windows theme and keeps following it while the app runs." />

            <c:CodeExample
                Title="App setup"
                Code="{Binding SetupCode}"
                Description="Merge only the control styles in App.xaml. Initialize() inserts the matching Light/Dark dictionary ahead of them at runtime — no theme dictionary is hardcoded." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
