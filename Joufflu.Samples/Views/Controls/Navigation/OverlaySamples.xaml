<UserControl
    x:Class="Joufflu.Samples.Views.Controls.Navigation.OverlaySamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Overlay" />

            <c:CodeExample
                Title="Modal overlays"
                Code="{Binding Code}"
                Description="Overlays are modal content shown above the page. They have a title bar with a close cross, a content area and an optional action bar. Multiple overlays stack.">
                <WrapPanel joufflu:Spacing.HorizontalGap="8" joufflu:Spacing.VerticalGap="8">
                    <Button Command="{Binding OpenSimpleCommand}" Content="Simple" />
                    <Button Command="{Binding OpenConfirmCommand}" Content="Confirm (with actions)" Style="{StaticResource Primary}" />
                    <Button Command="{Binding OpenFormCommand}" Content="Form" />
                    <Button Command="{Binding OpenStackedCommand}" Content="Stacked (×2)" />
                </WrapPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
