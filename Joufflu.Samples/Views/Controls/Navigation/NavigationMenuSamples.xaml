<UserControl
    x:Class="Joufflu.Samples.Views.Controls.Navigation.NavigationMenuSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:nav="clr-namespace:Joufflu.Navigation.Controls;assembly=Joufflu.Navigation">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Navigation menu" />

            <c:CodeExample
                Title="Collapsible side menu"
                Code="{Binding Code}"
                Description="The collapsible side menu in isolation, plugged into its own navigator. Use the chevron to collapse it to an icons-only rail.">
                <Border
                    Height="280"
                    BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                    BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
                    CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}"
                    SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <nav:NavigationMenu Navigator="{Binding DemoNavigator}" TargetResolver="{Binding ResolveTarget}">
                            <nav:NavigationTitle Title="Demo" />
                            <nav:NavigationItem Target="Home">
                                <nav:NavigationItem.Icon>
                                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Home}" />
                                </nav:NavigationItem.Icon>
                                Home
                            </nav:NavigationItem>
                            <nav:NavigationGroup Header="Parent" IsExpanded="True">
                                <nav:NavigationGroup.Icon>
                                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Folder}" />
                                </nav:NavigationGroup.Icon>
                                <nav:NavigationItem Target="Submenu 1">Submenu 1</nav:NavigationItem>
                                <nav:NavigationItem Target="Submenu 2">Submenu 2</nav:NavigationItem>
                                <nav:NavigationGroup Header="Parent" IsExpanded="True">
                                    <nav:NavigationGroup.Icon>
                                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Folder}" />
                                    </nav:NavigationGroup.Icon>
                                    <nav:NavigationItem Target="Nested submenu 1">Submenu 1</nav:NavigationItem>
                                    <nav:NavigationItem Target="Nested submenu 2">Submenu 2</nav:NavigationItem>
                                </nav:NavigationGroup>
                            </nav:NavigationGroup>
                            <nav:NavigationItem Target="Settings">
                                <nav:NavigationItem.Icon>
                                    <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Settings}" />
                                </nav:NavigationItem.Icon>
                                Settings
                            </nav:NavigationItem>
                        </nav:NavigationMenu>

                        <ContentControl
                            Grid.Column="1"
                            Margin="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{Binding DemoNavigator.CurrentPage}" />
                    </Grid>
                </Border>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
