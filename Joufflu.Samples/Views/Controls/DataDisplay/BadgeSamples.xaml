<UserControl
    x:Class="Joufflu.Samples.Views.Controls.DataDisplay.BadgeSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:controls="clr-namespace:Joufflu.Controls;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock Style="{StaticResource H1}" Text="Badge" />

            <c:CodeExample
                Title="Variants"
                Code="{Binding VariantsCode}"
                Description="A pill themed from the semantic brushes. Pick a variant with the Variant property.">
                <WrapPanel joufflu:Spacing.HorizontalGap="8">
                    <controls:Badge>Default</controls:Badge>
                    <controls:Badge Variant="Primary">Primary</controls:Badge>
                    <controls:Badge Variant="Secondary">Secondary</controls:Badge>
                    <controls:Badge Variant="Success">Success</controls:Badge>
                    <controls:Badge Variant="Info">Info</controls:Badge>
                    <controls:Badge Variant="Warning">Warning</controls:Badge>
                    <controls:Badge Variant="Danger">Danger</controls:Badge>
                    <controls:Badge Variant="Outline">Outline</controls:Badge>
                </WrapPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Sizes"
                Code="{Binding SizesCode}"
                Description="Sized through the inherited ControlProperties.Size attached property.">
                <StackPanel joufflu:Spacing.HorizontalGap="8" Orientation="Horizontal">
                    <controls:Badge joufflu:ControlProperties.Size="xs" Variant="Primary">xs</controls:Badge>
                    <controls:Badge joufflu:ControlProperties.Size="sm" Variant="Primary">sm</controls:Badge>
                    <controls:Badge joufflu:ControlProperties.Size="md" Variant="Primary">md</controls:Badge>
                    <controls:Badge joufflu:ControlProperties.Size="lg" Variant="Primary">lg</controls:Badge>
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
