<UserControl
    x:Class="Joufflu.Samples.Views.Controls.Feedback.SpinnerSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:controls="clr-namespace:Joufflu.Controls;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">

            <TextBlock Style="{StaticResource H1}" Text="Spinner" />
            <c:CodeExample
                Title="Loading indicator"
                Code="{Binding Code}"
                Description="An indeterminate loading indicator. Color comes from Foreground, diameter from ControlProperties.Size.">
                <StackPanel
                    VerticalAlignment="Center"
                    joufflu:Spacing.Gap="16,0"
                    Orientation="Horizontal">
                    <controls:Spinner joufflu:ControlProperties.Size="xs" />
                    <controls:Spinner joufflu:ControlProperties.Size="sm" />
                    <controls:Spinner joufflu:ControlProperties.Size="md" />
                    <controls:Spinner joufflu:ControlProperties.Size="lg" />
                    <controls:Spinner joufflu:ControlProperties.Size="lg" Foreground="{DynamicResource {x:Static joufflu:Brushes.DangerBrush}}" />
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
