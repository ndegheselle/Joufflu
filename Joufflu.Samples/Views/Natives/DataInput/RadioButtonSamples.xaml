<UserControl
    x:Class="Joufflu.Samples.Views.Natives.DataInput.RadioButtonSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Radio button" />

            <c:CodeExample
                Title="Groups"
                
                Description="Radio buttons sharing a GroupName are mutually exclusive. Two independent groups are shown side by side."
                Code="&lt;RadioButton GroupName=&quot;plan&quot; Content=&quot;Free&quot; IsChecked=&quot;True&quot; /&gt;&#x0a;&lt;RadioButton GroupName=&quot;plan&quot; Content=&quot;Pro&quot; /&gt;">
                <StackPanel Orientation="Horizontal" joufflu:Spacing.HorizontalGap="32">
                    <StackPanel joufflu:Spacing.Gap="8">
                        <RadioButton Content="Free" GroupName="plan" IsChecked="True" />
                        <RadioButton Content="Pro" GroupName="plan" />
                        <RadioButton Content="Team" GroupName="plan" />
                        <RadioButton Content="Disabled" GroupName="plan" IsEnabled="False" />
                    </StackPanel>
                    <StackPanel joufflu:Spacing.Gap="8">
                        <RadioButton Content="Monthly" GroupName="billing" IsChecked="True" />
                        <RadioButton Content="Yearly" GroupName="billing" />
                    </StackPanel>
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
