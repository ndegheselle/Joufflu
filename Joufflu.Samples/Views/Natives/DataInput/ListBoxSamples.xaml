<UserControl
    x:Class="Joufflu.Samples.Views.Natives.DataInput.ListBoxSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="List box" />

            <c:CodeExample
                Title="Single selection"
                Code="{Binding Code}"
                Description="A scrollable list bound to ItemsSource.">
                <ListBox
                    Height="160"
                    ItemsSource="{Binding Items}"
                    SelectedIndex="0" />
            </c:CodeExample>

            <c:CodeExample
                Title="Multiple selection"
                Code="{Binding MultiCode}"
                Description="SelectionMode=&quot;Extended&quot; lets the user pick several rows with Ctrl / Shift.">
                <ListBox
                    Height="160"
                    ItemsSource="{Binding Items}"
                    SelectionMode="Extended" />
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
