<UserControl
    x:Class="Joufflu.Samples.Views.Natives.DataInput.SliderSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Slider" />

            <c:CodeExample
                Title="Value"
                
                Code="{Binding ValueCode}"
                Description="Drag the thumb to change the bound value.">
                <StackPanel joufflu:Spacing.Gap="8">
                    <Slider
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding Value}" />
                    <TextBlock Text="{Binding Value, StringFormat={}Value: {0:0}}" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Ticks"
                
                Code="{Binding TicksCode}"
                Description="TickFrequency with IsSnapToTickEnabled steps the value in fixed increments.">
                <Slider
                    IsSnapToTickEnabled="True"
                    Maximum="10"
                    Minimum="0"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="4" />
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
