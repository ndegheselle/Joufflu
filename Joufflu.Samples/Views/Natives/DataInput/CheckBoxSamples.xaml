<UserControl
    x:Class="Joufflu.Samples.Views.Natives.DataInput.CheckBoxSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Check box" />

            <c:CodeExample
                Title="States"
                
                Code="{Binding StatesCode}"
                Description="Checked, unchecked, three-state (indeterminate) and disabled.">
                <StackPanel joufflu:Spacing.Gap="8">
                    <CheckBox Content="Bound" IsChecked="{Binding IsChecked}" />
                    <CheckBox Content="Unchecked" />
                    <CheckBox Content="Indeterminate" IsChecked="{x:Null}" IsThreeState="True" />
                    <CheckBox Content="Disabled" IsChecked="True" IsEnabled="False" />
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
