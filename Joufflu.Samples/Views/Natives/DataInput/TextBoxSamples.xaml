<UserControl
    x:Class="Joufflu.Samples.Views.Natives.DataInput.TextBoxSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock Style="{StaticResource H1}" Text="Text box" />

            <c:CodeExample
                Title="Text input"
                Code="{Binding TextCode}"
                Description="A standard TextBox bound to the view model.">
                <StackPanel joufflu:Spacing.Gap="4">
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox IsEnabled="False" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Sizes"
                Code="{Binding SizesCode}"
                Description="Height, font size and padding follow the inherited ControlProperties.Size.">
                <StackPanel joufflu:Spacing.Gap="4">
                    <TextBox joufflu:ControlProperties.Size="sm" Text="Small" />
                    <TextBox Text="Medium" />
                    <TextBox joufflu:ControlProperties.Size="lg" Text="Large" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Password &amp; multi-line"
                Code="{Binding OtherCode}"
                Description="PasswordBox shares the TextBox styling; a TextBox becomes multi-line with AcceptsReturn.">
                <StackPanel joufflu:Spacing.Gap="4">
                    <PasswordBox Password="secret" />
                    <TextBox
                        Height="70"
                        AcceptsReturn="True"
                        Text="Multi-line&#x0a;text box"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
