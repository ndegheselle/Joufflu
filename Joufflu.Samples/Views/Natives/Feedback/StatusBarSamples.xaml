<UserControl
    x:Class="Joufflu.Samples.Views.Natives.Feedback.StatusBarSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Status bar" />

            <c:CodeExample
                Title="Status bar"
                Description="A bar for status text and small indicators, usually docked at the bottom of a window."
                Code="&lt;StatusBar&gt;&#x0a;    &lt;StatusBarItem&gt;Ready&lt;/StatusBarItem&gt;&#x0a;    &lt;Separator /&gt;&#x0a;    &lt;StatusBarItem&gt;Ln 1, Col 1&lt;/StatusBarItem&gt;&#x0a;&lt;/StatusBar&gt;">
                <StatusBar>
                    <StatusBarItem>
                        <StackPanel Orientation="Horizontal" joufflu:Spacing.HorizontalGap="6">
                            <fonts:FontIcon VerticalAlignment="Center" Text="{x:Static fonts:LucideFontIcons.Check}" />
                            <TextBlock Text="Ready" />
                        </StackPanel>
                    </StatusBarItem>
                    <Separator />
                    <StatusBarItem Content="Ln 1, Col 1" />
                    <Separator />
                    <StatusBarItem HorizontalAlignment="Right" Content="UTF-8" />
                </StatusBar>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
