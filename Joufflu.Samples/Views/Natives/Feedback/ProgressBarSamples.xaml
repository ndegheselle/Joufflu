<UserControl
    x:Class="Joufflu.Samples.Views.Natives.Feedback.ProgressBarSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Progress bar" />

            <c:CodeExample
                Title="Determinate"
                Code="{Binding Code}"
                Description="Bind Value to show measurable progress. Drag the slider to update it.">
                <StackPanel joufflu:Spacing.Gap="8">
                    <ProgressBar
                        Height="8"
                        Maximum="100"
                        Value="{Binding Progress}" />
                    <Slider
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding Progress}" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Indeterminate"
                Code="{Binding IndeterminateCode}"
                Description="IsIndeterminate shows an animated bar when progress can't be measured.">
                <ProgressBar Height="8" IsIndeterminate="True" />
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
