<UserControl
    x:Class="Joufflu.Samples.Views.Natives.Actions.ButtonSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock Style="{StaticResource H1}" Text="Button" />

            <c:CodeExample
                Title="Variants"
                Code="{Binding VariantsCode}"
                Description="Named styles map to the design system's semantic brushes. Apply them through the Style property.">
                <WrapPanel joufflu:Spacing.Gap="8,0">
                    <Button>Default</Button>
                    <Button Style="{StaticResource Primary}">Primary</Button>
                    <Button Style="{StaticResource Secondary}">Secondary</Button>
                    <Button Style="{StaticResource Ghost}">Ghost</Button>
                    <Button Style="{StaticResource Success}">Success</Button>
                    <Button Style="{StaticResource Danger}">Danger</Button>
                    <Button Style="{StaticResource Info}">Info</Button>
                    <Button Style="{StaticResource Warning}">Warning</Button>
                    <Button IsEnabled="False">Disabled</Button>
                </WrapPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Soft"
                Code="{Binding SoftCode}"
                Description="A tinted background — the semantic hue at low opacity — with the hue itself as text. Because the tint is derived by opacity, it adapts to light/dark and to custom themes. Secondary is achromatic, so it uses a neutral foreground wash.">
                <WrapPanel joufflu:Spacing.Gap="8,0">
                    <Button Style="{StaticResource SoftPrimary}">Primary</Button>
                    <Button Style="{StaticResource SoftSecondary}">Secondary</Button>
                    <Button Style="{StaticResource SoftSuccess}">Success</Button>
                    <Button Style="{StaticResource SoftInfo}">Info</Button>
                    <Button Style="{StaticResource SoftWarning}">Warning</Button>
                    <Button Style="{StaticResource SoftDanger}">Danger</Button>
                </WrapPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Outline"
                Code="{Binding OutlineCode}"
                Description="A coloured border and text over a transparent fill; hovering fills it with the soft tint. Secondary uses the neutral border and foreground.">
                <WrapPanel joufflu:Spacing.Gap="8,0">
                    <Button Style="{StaticResource OutlinePrimary}">Primary</Button>
                    <Button Style="{StaticResource OutlineSecondary}">Secondary</Button>
                    <Button Style="{StaticResource OutlineSuccess}">Success</Button>
                    <Button Style="{StaticResource OutlineInfo}">Info</Button>
                    <Button Style="{StaticResource OutlineWarning}">Warning</Button>
                    <Button Style="{StaticResource OutlineDanger}">Danger</Button>
                </WrapPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Icon buttons"
                Code="{Binding IconCode}"
                Description="IsSquare makes a button as wide as it is tall — ideal for a single icon.">
                <StackPanel joufflu:Spacing.Gap="8,0" Orientation="Horizontal">
                    <Button joufflu:ControlProperties.IsSquare="True" Style="{StaticResource Primary}">
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Plus}" />
                    </Button>
                    <Button joufflu:ControlProperties.IsSquare="True">
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Settings}" />
                    </Button>
                    <Button joufflu:ControlProperties.IsSquare="True" Style="{StaticResource Danger}">
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Trash2}" />
                    </Button>
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Sizes"
                Code="{Binding SizesCode}"
                Description="The inherited ControlProperties.Size attached property scales height, font size and padding.">
                <StackPanel joufflu:Spacing.Gap="8,0" Orientation="Horizontal">
                    <Button VerticalAlignment="Center" joufflu:ControlProperties.Size="xs">XS</Button>
                    <Button VerticalAlignment="Center" joufflu:ControlProperties.Size="sm">SM</Button>
                    <Button VerticalAlignment="Center" joufflu:ControlProperties.Size="md">MD</Button>
                    <Button VerticalAlignment="Center" joufflu:ControlProperties.Size="lg">LG</Button>
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
