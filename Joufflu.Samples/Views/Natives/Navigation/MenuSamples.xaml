<UserControl
    x:Class="Joufflu.Samples.Views.Natives.Navigation.MenuSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Menu" />

            <c:CodeExample
                Title="Menu bar"
                Description="A classic menu bar with nested items, separators and checkable items."
                Code="&lt;Menu&gt;&#x0a;    &lt;MenuItem Header=&quot;_File&quot;&gt;&#x0a;        &lt;MenuItem Header=&quot;_New&quot; /&gt;&#x0a;        &lt;Separator /&gt;&#x0a;        &lt;MenuItem Header=&quot;E_xit&quot; /&gt;&#x0a;    &lt;/MenuItem&gt;&#x0a;&lt;/Menu&gt;">
                <Menu>
                    <MenuItem Header="_File">
                        <MenuItem Header="_New" />
                        <MenuItem Header="_Open" />
                        <Separator />
                        <MenuItem Header="E_xit" />
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Undo" />
                        <MenuItem Header="_Redo" />
                        <Separator />
                        <MenuItem Header="Word _wrap" IsCheckable="True" IsChecked="True" />
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Zoom">
                            <MenuItem Header="100%" />
                            <MenuItem Header="150%" />
                        </MenuItem>
                    </MenuItem>
                </Menu>
            </c:CodeExample>

            <c:CodeExample
                Title="Context menu"
                Description="Right-click the area below to open its ContextMenu."
                Code="&lt;Border&gt;&#x0a;    &lt;Border.ContextMenu&gt;&#x0a;        &lt;ContextMenu&gt;&#x0a;            &lt;MenuItem Header=&quot;Cut&quot; /&gt;&#x0a;        &lt;/ContextMenu&gt;&#x0a;    &lt;/Border.ContextMenu&gt;&#x0a;&lt;/Border&gt;">
                <Border
                    Height="80"
                    Background="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}"
                    BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                    BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
                    CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="Right-click me" />
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Cut" />
                            <MenuItem Header="Copy" />
                            <MenuItem Header="Paste" />
                            <Separator />
                            <MenuItem Header="Select all" />
                        </ContextMenu>
                    </Border.ContextMenu>
                </Border>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
