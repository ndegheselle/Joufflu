<UserControl
    x:Class="Joufflu.Samples.Views.Natives.Navigation.ToolBarSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Tool bar" />

            <c:CodeExample
                Title="Tool bar"
                Description="A ToolBar restyles the buttons, toggles and separators placed inside it. Overflow items collapse into the chevron when space runs out."
                Code="&lt;ToolBar&gt;&#x0a;    &lt;Button&gt;...&lt;/Button&gt;&#x0a;    &lt;ToggleButton&gt;...&lt;/ToggleButton&gt;&#x0a;    &lt;Separator /&gt;&#x0a;&lt;/ToolBar&gt;">
                <ToolBarTray>
                    <ToolBar>
                        <Button>
                            <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Plus}" />
                        </Button>
                        <Button>
                            <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Settings}" />
                        </Button>
                        <Separator />
                        <ToggleButton IsChecked="True">
                            <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Bell}" />
                        </ToggleButton>
                        <ToggleButton>
                            <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Home}" />
                        </ToggleButton>
                        <Separator />
                        <Button>
                            <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Trash2}" />
                        </Button>
                    </ToolBar>
                </ToolBarTray>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
