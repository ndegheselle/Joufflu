<UserControl
    x:Class="Joufflu.Samples.Views.Natives.Layout.ExpanderSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Expander" />

            <c:CodeExample
                Title="Collapsible section"
                
                Description="Click the header to reveal or hide the content."
                Code="&lt;Expander Header=&quot;Details&quot; IsExpanded=&quot;True&quot;&gt;&#x0a;    ...&#x0a;&lt;/Expander&gt;">
                <StackPanel joufflu:Spacing.Gap="8">
                    <Expander Header="Details" IsExpanded="True">
                        <TextBlock Margin="0,8,0,0" Text="Content revealed by the expander." TextWrapping="Wrap" />
                    </Expander>
                    <Expander Header="More options">
                        <StackPanel Margin="0,8,0,0" joufflu:Spacing.Gap="4">
                            <CheckBox Content="Option A" />
                            <CheckBox Content="Option B" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
