<UserControl
    x:Class="Joufflu.Samples.Views.Natives.Layout.GroupBoxSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Group box" />

            <c:CodeExample
                Title="Grouped content"
                
                Description="A titled frame around a set of related controls."
                Code="&lt;GroupBox Header=&quot;Account&quot;&gt;&#x0a;    ...&#x0a;&lt;/GroupBox&gt;">
                <GroupBox Header="Account">
                    <StackPanel joufflu:Spacing.Gap="8">
                        <TextBox Text="Username" />
                        <CheckBox Content="Remember me" IsChecked="True" />
                    </StackPanel>
                </GroupBox>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
