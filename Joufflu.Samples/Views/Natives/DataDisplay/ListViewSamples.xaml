<UserControl
    x:Class="Joufflu.Samples.Views.Natives.DataDisplay.ListViewSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="List view" />

            <c:CodeExample
                Title="Grid view columns"
                Code="{Binding Code}"
                Description="A ListView with a GridView shows tabular, sortable-looking columns with draggable headers.">
                <ListView Height="200" ItemsSource="{Binding People}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="160" Header="Name" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Width="140" Header="Role" DisplayMemberBinding="{Binding Role}" />
                            <GridViewColumn Width="80" Header="Age" DisplayMemberBinding="{Binding Age}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
