<UserControl
    x:Class="Joufflu.Samples.Views.Natives.DataDisplay.DataGridSamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="{StaticResource {x:Static joufflu:Dimensions.SpacingThickness}}" VerticalScrollBarVisibility="Auto">
        <StackPanel

            joufflu:Spacing.Gap="{StaticResource {x:Static joufflu:Dimensions.Spacing}}">
            <TextBlock
                Style="{StaticResource H1}"
                Text="Data grid" />

            <c:CodeExample
                Title="Editable grid"
                Code="{Binding Code}"
                Description="A DataGrid with explicit columns. Cells are editable and rows can be selected.">
                <DataGrid
                    Height="220"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    ItemsSource="{Binding People}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Binding="{Binding Name}" Header="Name" />
                        <DataGridTextColumn Width="*" Binding="{Binding Role}" Header="Role" />
                        <DataGridTextColumn Width="80" Binding="{Binding Age}" Header="Age" />
                    </DataGrid.Columns>
                </DataGrid>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
