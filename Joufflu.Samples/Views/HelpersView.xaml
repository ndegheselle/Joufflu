<UserControl
    x:Class="Joufflu.Samples.Views.HelpersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock
                Margin="0,0,0,16"
                FontSize="22"
                FontWeight="Bold"
                Text="Helpers" />

            <c:CodeExample
                Title="ControlProperties.Size"
                Code="{Binding SizeCode}"
                Description="Size is an inherited attached property. Set it on any control, or on a parent panel to size a whole group at once.">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="xs">xs</Button>
                        <Button
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="sm">sm</Button>
                        <Button
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="md">md</Button>
                        <Button
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="lg">lg</Button>
                    </StackPanel>

                    <Border
                        Margin="0,16,0,0"
                        Padding="12"
                        Background="{DynamicResource {x:Static joufflu:Brushes.Background200Brush}}"
                        CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">
                        <StackPanel joufflu:ControlProperties.Size="lg" Orientation="Horizontal">
                            <TextBox Width="160" VerticalAlignment="Center" Text="Inherited lg" />
                            <ComboBox
                                Width="120"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                SelectedIndex="0">
                                <ComboBoxItem>Large</ComboBoxItem>
                                <ComboBoxItem>Items</ComboBoxItem>
                            </ComboBox>
                            <Button Margin="8,0,0,0" VerticalAlignment="Center">OK</Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="ControlProperties.IsSquare"
                Code="{Binding SquareCode}"
                Description="Forces width to equal height and zeroes padding for clean icon buttons.">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        joufflu:ControlProperties.IsSquare="True"
                        joufflu:ControlProperties.Size="sm">
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                    </Button>
                    <Button
                        Margin="0,0,8,0"
                        joufflu:ControlProperties.IsSquare="True"
                        joufflu:ControlProperties.Size="md">
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                    </Button>
                    <Button
                        Margin="0,0,8,0"
                        joufflu:ControlProperties.IsSquare="True"
                        joufflu:ControlProperties.Size="lg">
                        <fonts:FontIcon Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                    </Button>
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Spacing.Gap"
                Code="{Binding GapCode}"
                Description="Gap adds spacing between the children of a StackPanel, WrapPanel or Grid by applying margins. Use Gap for a uniform gap on both axes, or HorizontalGap / VerticalGap to set a single axis.">
                <StackPanel>
                    <!-- StackPanel: gap along the Orientation axis -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontWeight="SemiBold"
                        Text="StackPanel (Gap=8)" />
                    <StackPanel joufflu:Spacing.Gap="8" Orientation="Horizontal">
                        <Button>One</Button>
                        <Button>Two</Button>
                        <Button>Three</Button>
                    </StackPanel>

                    <!-- WrapPanel: independent gap per axis -->
                    <TextBlock
                        Margin="0,20,0,6"
                        FontWeight="SemiBold"
                        Text="WrapPanel (HorizontalGap=8, VerticalGap=12)" />
                    <WrapPanel
                        MaxWidth="260"
                        HorizontalAlignment="Left"
                        joufflu:Spacing.HorizontalGap="8"
                        joufflu:Spacing.VerticalGap="12">
                        <Button>Alpha</Button>
                        <Button>Beta</Button>
                        <Button>Gamma</Button>
                        <Button>Delta</Button>
                        <Button>Epsilon</Button>
                    </WrapPanel>

                    <!-- Grid: gap between rows and columns -->
                    <TextBlock
                        Margin="0,20,0,6"
                        FontWeight="SemiBold"
                        Text="Grid (Gap=12)" />
                    <Grid
                        HorizontalAlignment="Left"
                        joufflu:Spacing.Gap="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0">Top left</Button>
                        <Button Grid.Row="0" Grid.Column="1">Top right</Button>
                        <Button Grid.Row="1" Grid.Column="0">Bottom left</Button>
                        <Button Grid.Row="1" Grid.Column="1">Bottom right</Button>
                    </Grid>
                </StackPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
