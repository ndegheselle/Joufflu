<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">

    <!--  A custom "Synthwave" palette shipped by the sample app, registered with ThemeManager at startup.  -->

    <!--  Foreground Colors  -->
    <Color x:Key="{x:Static joufflu:Colors.ForegroundColor}">#F9F7FD</Color>
    <Color x:Key="{x:Static joufflu:Colors.Foreground100Color}">#ABA7B7</Color>
    <Color x:Key="{x:Static joufflu:Colors.Foreground200Color}">#7F798F</Color>

    <!--  Border Colors  -->
    <Color x:Key="{x:Static joufflu:Colors.BorderColor}">#3A2A63</Color>
    <Color x:Key="{x:Static joufflu:Colors.Border100Color}">#2A1E4C</Color>

    <!--  Background Colors  -->
    <Color x:Key="{x:Static joufflu:Colors.BackgroundColor}">#1B1235</Color>
    <Color x:Key="{x:Static joufflu:Colors.Background100Color}">#241A4A</Color>
    <Color x:Key="{x:Static joufflu:Colors.Background200Color}">#2D1B69</Color>

    <!--  Primary  -->
    <Color x:Key="{x:Static joufflu:Colors.PrimaryColor}">#E779C1</Color>
    <Color x:Key="{x:Static joufflu:Colors.Primary100Color}">#C467A4</Color>
    <Color x:Key="{x:Static joufflu:Colors.PrimaryContentColor}">#2A0A20</Color>

    <!--  Secondary  -->
    <Color x:Key="{x:Static joufflu:Colors.SecondaryColor}">#58C7F3</Color>
    <Color x:Key="{x:Static joufflu:Colors.Secondary100Color}">#4BA9CF</Color>
    <Color x:Key="{x:Static joufflu:Colors.SecondaryContentColor}">#06222E</Color>

    <!--  Success  -->
    <Color x:Key="{x:Static joufflu:Colors.SuccessColor}">#71EAD2</Color>
    <Color x:Key="{x:Static joufflu:Colors.Success100Color}">#60C7B2</Color>
    <Color x:Key="{x:Static joufflu:Colors.SuccessContentColor}">#05261F</Color>

    <!--  Info  -->
    <Color x:Key="{x:Static joufflu:Colors.InfoColor}">#53C0F3</Color>
    <Color x:Key="{x:Static joufflu:Colors.Info100Color}">#47A3CF</Color>
    <Color x:Key="{x:Static joufflu:Colors.InfoContentColor}">#06222E</Color>

    <!--  Warning  -->
    <Color x:Key="{x:Static joufflu:Colors.WarningColor}">#E2D562</Color>
    <Color x:Key="{x:Static joufflu:Colors.Warning100Color}">#C0B553</Color>
    <Color x:Key="{x:Static joufflu:Colors.WarningContentColor}">#2E2905</Color>

    <!--  Danger  -->
    <Color x:Key="{x:Static joufflu:Colors.DangerColor}">#FD6F9C</Color>
    <Color x:Key="{x:Static joufflu:Colors.Danger100Color}">#D75E85</Color>
    <Color x:Key="{x:Static joufflu:Colors.DangerContentColor}">#2E0716</Color>

    <!--  Foreground Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.ForegroundBrush}" Color="{DynamicResource {x:Static joufflu:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Foreground100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Foreground100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Foreground200Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Foreground200Color}}" />

    <!--  Border Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.BorderBrush}" Color="{DynamicResource {x:Static joufflu:Colors.BorderColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Border100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Border100Color}}" />

    <!--  Background Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.BackgroundBrush}" Color="{DynamicResource {x:Static joufflu:Colors.BackgroundColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Background100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Background100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Background200Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Background200Color}}" />

    <!--  Semantic Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.PrimaryBrush}" Color="{DynamicResource {x:Static joufflu:Colors.PrimaryColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Primary100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Primary100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.PrimaryContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.PrimaryContentColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SecondaryBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SecondaryColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Secondary100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Secondary100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SecondaryContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SecondaryContentColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SuccessBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SuccessColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Success100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Success100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SuccessContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SuccessContentColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.InfoBrush}" Color="{DynamicResource {x:Static joufflu:Colors.InfoColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Info100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Info100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.InfoContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.InfoContentColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.WarningBrush}" Color="{DynamicResource {x:Static joufflu:Colors.WarningColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Warning100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Warning100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.WarningContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.WarningContentColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.DangerBrush}" Color="{DynamicResource {x:Static joufflu:Colors.DangerColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Danger100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Danger100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.DangerContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.DangerContentColor}}" />

</ResourceDictionary>
